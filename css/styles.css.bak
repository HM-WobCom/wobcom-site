/* Wobcom — marketing site */

:root {
  --color-bg: #f7f9fc;
  --color-surface: #ffffff;
  --color-text: #1a2332;
  --color-muted: #5c6678;
  --color-border: #e4e9f2;
  --color-navy: #0c2340;
  --color-navy-deep: #07182c;
  --color-accent: #1e5a8e;
  --color-accent-soft: #5b8ec4;
  --color-accent-glow: rgba(30, 90, 142, 0.18);
  --color-charcoal: #141820;
  --shadow-sm: 0 4px 14px rgba(12, 35, 64, 0.08);
  --shadow-md: 0 18px 50px rgba(12, 35, 64, 0.12);
  --shadow-lg: 0 28px 80px rgba(7, 24, 44, 0.18);
  --radius-sm: 10px;
  --radius-md: 16px;
  --radius-lg: 24px;
  --font: "DM Sans", system-ui, -apple-system, sans-serif;
  --transition: 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  --header-h: 72px;
}

*,
*::before,
*::after {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  font-family: var(--font);
  font-size: 1rem;
  line-height: 1.6;
  color: var(--color-text);
  background: var(--color-bg);
  -webkit-font-smoothing: antialiased;
}

img {
  max-width: 100%;
  height: auto;
  display: block;
}

a {
  color: inherit;
  text-decoration: none;
}

.container {
  width: min(1120px, 100% - 40px);
  margin-inline: auto;
}

/* Header */

.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(228, 233, 242, 0.8);
  transition: box-shadow var(--transition);
}

.site-header.is-scrolled {
  box-shadow: var(--shadow-sm);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  min-height: var(--header-h);
}

.logo {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-weight: 700;
  font-size: 1.125rem;
  letter-spacing: -0.02em;
}

.logo-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: linear-gradient(145deg, var(--color-navy), var(--color-accent));
  color: #fff;
  font-size: 1rem;
}

.logo--footer .logo-mark {
  width: 32px;
  height: 32px;
  font-size: 0.9rem;
}

.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 6px;
  padding: 10px;
  background: none;
  border: none;
  cursor: pointer;
  border-radius: var(--radius-sm);
}

.nav-toggle-bar {
  width: 22px;
  height: 2px;
  background: var(--color-navy);
  border-radius: 1px;
  transition: transform var(--transition), opacity var(--transition);
}

.site-nav .nav-list {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.site-nav a {
  padding: 0.5rem 0.85rem;
  border-radius: 999px;
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--color-muted);
  transition: color var(--transition), background var(--transition);
}

.site-nav a:hover,
.site-nav a:focus-visible {
  color: var(--color-navy);
  background: rgba(30, 90, 142, 0.08);
  outline: none;
}

.header-cta {
  flex-shrink: 0;
}

/* Buttons */

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.85rem 1.5rem;
  font-family: inherit;
  font-size: 0.9375rem;
  font-weight: 600;
  border-radius: 999px;
  border: none;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow var(--transition), background var(--transition),
    color var(--transition);
}

.btn-sm {
  padding: 0.55rem 1.15rem;
  font-size: 0.875rem;
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-navy) 0%, #153a5c 100%);
  color: #fff;
  box-shadow: 0 4px 20px rgba(12, 35, 64, 0.25);
}

.btn-primary:hover,
.btn-primary:focus-visible {
  transform: translateY(-1px);
  box-shadow: 0 8px 28px rgba(12, 35, 64, 0.35);
  outline: none;
}

.btn-ghost {
  background: #fff;
  color: var(--color-navy);
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-sm);
}

.btn-ghost:hover,
.btn-ghost:focus-visible {
  border-color: var(--color-accent-soft);
  color: var(--color-accent);
  outline: none;
}

.btn-block {
  width: 100%;
}

/* Hero */

.hero {
  position: relative;
  padding: clamp(3rem, 8vw, 5.5rem) 0 clamp(4rem, 10vw, 6rem);
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(120% 80% at 85% 0%, rgba(91, 142, 196, 0.2) 0%, transparent 55%),
    radial-gradient(80% 60% at 10% 20%, rgba(30, 90, 142, 0.12) 0%, transparent 50%),
    linear-gradient(180deg, #ffffff 0%, var(--color-bg) 100%);
  pointer-events: none;
}

.hero-grid {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(2rem, 5vw, 4rem);
  align-items: center;
}

.eyebrow {
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin: 0 0 1rem;
}

.hero-title {
  font-size: clamp(2rem, 4vw, 2.75rem);
  line-height: 1.15;
  letter-spacing: -0.03em;
  margin: 0 0 1.25rem;
  font-weight: 700;
  color: var(--color-navy);
}

.text-accent {
  color: var(--color-accent);
  font-weight: 700;
}

.hero-lead {
  font-size: 1.125rem;
  color: var(--color-muted);
  margin: 0 0 1.75rem;
  max-width: 34rem;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.hero-note {
  font-size: 0.9rem;
  color: var(--color-muted);
  margin: 0;
  padding: 1rem 1.25rem;
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  max-width: 36rem;
}

.hero-note strong {
  color: var(--color-navy);
}

/* Mockup */

.hero-visual {
  position: relative;
  justify-self: end;
  width: 100%;
  max-width: 440px;
}

.mockup-frame {
  background: linear-gradient(135deg, #1a2f45 0%, #0c2340 50%, #0a1a2e 100%);
  border-radius: var(--radius-lg);
  padding: 1rem 1rem 1.25rem;
  box-shadow: var(--shadow-lg);
  transform: perspective(1000px) rotateY(-4deg) rotateX(2deg);
  transition: transform 0.6s ease;
}

.hero-visual:hover .mockup-frame {
  transform: perspective(1000px) rotateY(-2deg) rotateX(1deg) translateY(-4px);
}

.mockup-chrome {
  display: flex;
  gap: 6px;
  margin-bottom: 0.75rem;
}

.mockup-chrome span {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.mockup-chrome span:nth-child(1) {
  background: #ff5f57;
}

.mockup-chrome span:nth-child(2) {
  background: #febc2e;
}

.mockup-chrome span:nth-child(3) {
  background: #28c840;
}

.mockup-screen {
  display: grid;
  grid-template-columns: 72px 1fr;
  gap: 1rem;
  min-height: 220px;
  background: linear-gradient(180deg, #f0f4f8 0%, #e8eef5 100%);
  border-radius: var(--radius-sm);
  padding: 1rem;
}

.mockup-sidebar {
  background: #fff;
  border-radius: 8px;
  box-shadow: var(--shadow-sm);
}

.mockup-main {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.mockup-hero-bar {
  height: 48px;
  border-radius: 8px;
  background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-accent-soft) 100%);
  opacity: 0.9;
}

.mockup-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6px;
}

.mockup-card {
  height: 52px;
  border-radius: 6px;
  background: #fff;
  box-shadow: 0 2px 8px rgba(12, 35, 64, 0.06);
}

.mockup-chart {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80px;
}

.chart-svg {
  width: 100px;
  height: auto;
}

.hero-float-card {
  position: absolute;
  bottom: -12px;
  left: -8px;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.85rem 1.1rem;
  background: #fff;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
  border: 1px solid var(--color-border);
  animation: float 5s ease-in-out infinite;
}

@keyframes float {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8px);
  }
}

.float-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: linear-gradient(135deg, #e8f8ef, #c8f0dc);
  color: #1a7f4c;
  font-weight: 700;
  font-size: 1rem;
}

.float-sub {
  display: block;
  font-size: 0.8rem;
  color: var(--color-muted);
}

/* Sections */

.section {
  padding: clamp(3.5rem, 8vw, 5.5rem) 0;
}

.section-title {
  font-size: clamp(1.75rem, 3vw, 2.25rem);
  letter-spacing: -0.02em;
  margin: 0 0 0.75rem;
  color: var(--color-navy);
  font-weight: 700;
}

.section-title--on-dark {
  color: #fff;
}

.section-subtitle {
  font-size: 1.0625rem;
  color: var(--color-muted);
  margin: 0;
  max-width: 560px;
}

.section-subtitle--on-dark {
  color: rgba(255, 255, 255, 0.72);
}

.section-head.center {
  text-align: center;
  margin-bottom: 3rem;
}

.section-head.center .section-subtitle {
  margin-inline: auto;
}

.section-lead {
  font-size: 1.125rem;
  color: var(--color-muted);
  margin: 0 0 1rem;
}

/* About */

.about-grid {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: clamp(2rem, 5vw, 4rem);
  align-items: center;
}

.about-card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 2rem;
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-sm);
}

.about-avatar-stack {
  display: flex;
  margin-bottom: 1.25rem;
}

.about-avatar-stack .avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 3px solid #fff;
  margin-left: -12px;
  background: linear-gradient(135deg, #cfd8e6, #8fa3bd);
  box-shadow: var(--shadow-sm);
}

.about-avatar-stack .avatar:first-child {
  margin-left: 0;
}

.about-avatar-stack .avatar:nth-child(2) {
  background: linear-gradient(135deg, #b8c9d9, #6b849a);
}

.about-avatar-stack .avatar:nth-child(3) {
  background: linear-gradient(135deg, #dfe6f0, #9aa8bc);
}

.about-avatar-stack .avatar:nth-child(4) {
  background: linear-gradient(135deg, #1e5a8e, #5b8ec4);
}

.about-card-caption {
  margin: 0;
  font-size: 0.9rem;
  color: var(--color-muted);
}

.checklist {
  list-style: none;
  margin: 1.25rem 0 1.5rem;
  padding: 0;
}

.checklist li {
  position: relative;
  padding-left: 1.75rem;
  margin-bottom: 0.75rem;
  color: var(--color-text);
}

.checklist li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.45em;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-soft));
  box-shadow: 0 0 0 3px var(--color-accent-glow);
}

.text-link {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-weight: 600;
  color: var(--color-accent);
  transition: gap var(--transition);
}

.text-link:hover,
.text-link:focus-visible {
  gap: 0.5rem;
  outline: none;
}

.text-link-arrow {
  transition: transform var(--transition);
}

.text-link:hover .text-link-arrow {
  transform: translateX(3px);
}

/* Features */

.features-wrap {
  background: linear-gradient(180deg, var(--color-bg) 0%, #ffffff 40%, #f0f5fc 100%);
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  grid-template-rows: auto auto auto;
  gap: 1.25rem;
}

.feature-card--pos-custom {
  grid-column: 1 / span 2;
  grid-row: 1 / span 2;
}

.feature-card--pos-admin {
  grid-column: 3;
  grid-row: 1;
}

.feature-card--pos-secure {
  grid-column: 3;
  grid-row: 2;
}

.feature-card--pos-product-mgmt {
  grid-column: 1 / span 2;
  grid-row: 3;
}

.feature-card--pos-mobile {
  grid-column: 3;
  grid-row: 3;
}

.feature-card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 1.75rem;
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-sm);
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
}

.feature-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
  border-color: rgba(30, 90, 142, 0.18);
}

.feature-card--accent {
  background: linear-gradient(160deg, var(--color-navy) 0%, #153a5c 100%);
  color: #fff;
  border-radius: var(--radius-lg);
  border: none;
}

.feature-card--accent .feature-title {
  color: #fff;
}

.feature-card--accent p {
  color: rgba(255, 255, 255, 0.82);
}

.feature-card--accent .feature-icon {
  color: #fff;
  background: rgba(255, 255, 255, 0.12);
}

.feature-card-visual {
  border-radius: var(--radius-md);
  margin-bottom: 1.25rem;
  overflow: hidden;
  min-height: 220px;
  background: linear-gradient(135deg, #eef3f9 0%, #dce6f2 100%);
}

.feature-card-visual--site {
  padding: 1rem;
}

.mini-browser {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.mini-bar {
  height: 28px;
  background: #e8eef5;
}

.mini-body {
  padding: 1rem;
}

.mini-nav {
  height: 8px;
  width: 40%;
  border-radius: 4px;
  background: var(--color-border);
  margin-bottom: 1rem;
}

.mini-hero {
  height: 72px;
  border-radius: 10px;
  background: linear-gradient(90deg, var(--color-accent), var(--color-accent-soft));
  margin-bottom: 0.75rem;
}

.mini-row {
  display: flex;
  gap: 8px;
}

.mini-row span {
  flex: 1;
  height: 48px;
  border-radius: 8px;
  background: #f3f6fa;
}

.feature-title {
  font-size: 1.125rem;
  margin: 0 0 0.5rem;
  color: var(--color-navy);
  font-weight: 700;
}

.feature-card p {
  margin: 0;
  font-size: 0.9375rem;
  color: var(--color-muted);
}

.feature-icon {
  width: 52px;
  height: 52px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1rem;
  color: var(--color-accent);
  background: rgba(30, 90, 142, 0.1);
}

.feature-icon--soft {
  background: rgba(30, 90, 142, 0.08);
}

/* Why */

.why {
  background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(30, 90, 142, 0.12) 0%, transparent 55%),
    var(--color-charcoal);
  color: #fff;
}

.why-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
}

.why-item {
  display: flex;
  gap: 1.25rem;
  padding: 1.75rem;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-lg);
  transition: background var(--transition), transform var(--transition);
}

.why-item:hover {
  background: rgba(255, 255, 255, 0.07);
  transform: translateY(-2px);
}

.why-num {
  font-size: 0.8125rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--color-accent-soft);
  flex-shrink: 0;
}

.why-heading {
  font-size: 1.125rem;
  margin: 0 0 0.5rem;
  font-weight: 600;
}

.why-item p {
  margin: 0;
  font-size: 0.9375rem;
  color: rgba(255, 255, 255, 0.72);
}

/* Showcase */

.showcase-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

.showcase-card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-sm);
  transition: transform var(--transition), box-shadow var(--transition);
}

.showcase-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-md);
}

.showcase-visual {
  aspect-ratio: 16 / 10;
  position: relative;
}

.showcase-visual--a {
  background: linear-gradient(145deg, #0d4a5c 0%, #1a7a8c 40%, #2a9aad 100%);
}

.showcase-pedestal {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 65%, rgba(255, 255, 255, 0.15) 0%, transparent 45%),
    linear-gradient(180deg, transparent 55%, rgba(0, 0, 0, 0.18) 100%);
}

.showcase-pedestal::before,
.showcase-pedestal::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  box-shadow: inset 0 0 20px rgba(255, 255, 255, 0.2);
}

.showcase-pedestal::before {
  width: 72px;
  height: 72px;
  left: 50%;
  top: 38%;
  transform: translate(-50%, -50%);
  border: 2px solid rgba(255, 255, 255, 0.25);
}

.showcase-pedestal::after {
  width: 120px;
  height: 16px;
  left: 50%;
  bottom: 22%;
  transform: translateX(-50%);
  border-radius: 8px;
  background: rgba(0, 0, 0, 0.18);
}

.showcase-visual--b {
  background: linear-gradient(180deg, #f5f6f8 0%, #e4e7ea 100%);
}

.showcase-mannequin {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 30% 40%, rgba(180, 190, 200, 0.35) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 45%, rgba(160, 170, 185, 0.3) 0%, transparent 45%);
}

.showcase-mannequin::before,
.showcase-mannequin::after {
  content: "";
  position: absolute;
  bottom: 18%;
  width: 40px;
  height: 140px;
  border-radius: 20px;
  background: linear-gradient(180deg, #d8dde3, #c0c8d0);
  opacity: 0.85;
}

.showcase-mannequin::before {
  left: 32%;
  transform: rotate(-3deg);
}

.showcase-mannequin::after {
  right: 32%;
  transform: rotate(3deg);
}

.showcase-body {
  padding: 1.75rem;
}

.showcase-name {
  margin: 0 0 0.35rem;
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-navy);
}

.showcase-meta {
  margin: 0;
  font-size: 0.875rem;
  color: var(--color-muted);
}

/* Contact */

.contact-shell {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(2rem, 5vw, 3.5rem);
  padding: clamp(2rem, 5vw, 3rem);
  background: linear-gradient(135deg, #ffffff 0%, #f0f5fc 100%);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-md);
}

.contact-intro .section-title {
  margin-bottom: 1rem;
}

.contact-meta {
  margin-top: 1.5rem;
}

.contact-email {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-weight: 600;
  color: var(--color-accent);
}

.contact-email-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: rgba(30, 90, 142, 0.1);
  font-size: 1rem;
}

.contact-form {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.form-row {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.form-row label {
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--color-navy);
}

.form-row input,
.form-row textarea {
  font-family: inherit;
  font-size: 1rem;
  padding: 0.75rem 1rem;
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border);
  background: #fff;
  transition: border-color var(--transition), box-shadow var(--transition);
}

.form-row input:focus,
.form-row textarea:focus {
  outline: none;
  border-color: var(--color-accent-soft);
  box-shadow: 0 0 0 3px var(--color-accent-glow);
}

.form-row textarea {
  resize: vertical;
  min-height: 120px;
}

.form-footnote {
  min-height: 1.25rem;
  margin: 0;
  font-size: 0.875rem;
  color: var(--color-muted);
  text-align: center;
}

.label-optional {
  font-weight: 500;
  color: var(--color-muted);
}

.form-row--hp {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.form-footnote.form-success {
  color: #137a4a;
  font-weight: 500;
}

.form-footnote.form-error {
  color: #b42318;
}

.btn.is-loading {
  pointer-events: none;
  opacity: 0.85;
}

.btn .btn-loading.hidden,
.btn .hidden {
  display: none;
}

.btn.is-loading .btn-label {
  display: none;
}

.btn.is-loading .btn-loading {
  display: inline;
}

/* Footer */

.site-footer {
  padding: 2.5rem 0;
  background: #fff;
  border-top: 1px solid var(--color-border);
}

.footer-inner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 1.25rem;
}

.footer-nav {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.footer-nav a {
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--color-muted);
  transition: color var(--transition);
}

.footer-nav a:hover,
.footer-nav a:focus-visible {
  color: var(--color-navy);
  outline: none;
}

.footer-social {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 10px;
  color: var(--color-muted);
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  transition: color var(--transition), background var(--transition), transform var(--transition);
}

.social-link:hover,
.social-link:focus-visible {
  color: var(--color-accent);
  background: rgba(30, 90, 142, 0.08);
  transform: translateY(-2px);
  outline: none;
}

.footer-copy {
  margin: 0;
  font-size: 0.8125rem;
  color: var(--color-muted);
  width: 100%;
  text-align: center;
}

@media (min-width: 768px) {
  .footer-copy {
    width: auto;
    text-align: right;
  }
}

/* Reveal animation */

.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.7s var(--transition), transform 0.7s var(--transition);
}

.reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* Responsive */

@media (max-width: 960px) {
  .hero-grid {
    grid-template-columns: 1fr;
  }

  .hero-visual {
    justify-self: center;
    max-width: 400px;
  }

  .about-grid {
    grid-template-columns: 1fr;
  }

  .features-grid {
    grid-template-columns: 1fr;
  }

  .feature-card--pos-custom,
  .feature-card--pos-admin,
  .feature-card--pos-secure,
  .feature-card--pos-product-mgmt,
  .feature-card--pos-mobile {
    grid-column: auto;
    grid-row: auto;
  }

  .why-list {
    grid-template-columns: 1fr;
  }

  .showcase-grid {
    grid-template-columns: 1fr;
  }

  .contact-shell {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 820px) {
  .nav-toggle {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .header-cta {
    display: none;
  }

  .site-nav {
    position: fixed;
    inset: var(--header-h) 0 auto 0;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 1.25rem 1.25rem;
    transform: translateY(-120%);
    opacity: 0;
    visibility: hidden;
    transition: transform var(--transition), opacity var(--transition), visibility var(--transition);
  }

  .site-nav.is-open {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }

  .site-nav .nav-list {
    flex-direction: column;
    align-items: stretch;
  }

  .site-nav a {
    padding: 0.75rem 1rem;
  }

  body.nav-open {
    overflow: hidden;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }

  html {
    scroll-behavior: auto;
  }

  .reveal {
    opacity: 1;
    transform: none;
  }
}
