# Server
PORT=3000
NODE_ENV=development

# Session cookie signing (use a long random string in production)
SESSION_SECRET=replace-with-long-random-string

# Admin dashboard — password is compared via SHA-256 (set a strong password)
ADMIN_PASSWORD=change-this-strong-password

# SQLite database file (created automatically)
DATABASE_PATH=./data/wobcom.db

# Demo form rate limit (optional) — default: 200/1min in dev, 60/15min in production
# DEMO_RATE_LIMIT_MAX=200
# DEMO_RATE_LIMIT_WINDOW_MS=900000

# Email — demo form notifications (use only this address for testing)
EMAIL_TO=wobcom09@gmail.com
EMAIL_FROM="Wobcom <wobcom09@gmail.com>"

# Gmail SMTP (create an App Password: Google Account → Security → 2-Step Verification → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=wobcom09@gmail.com
SMTP_PASS=your-16-char-app-password

# Optional: Google reCAPTCHA v3 — set BOTH keys or leave BOTH unset (only one will break the form)
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
